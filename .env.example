# 1-CUISINESG Authentication
# Set ALL of these in Vercel → Project Settings → Environment Variables

# ═══════ REQUIRED ═══════

# Master Admin credentials (your login)
MASTER_ADMIN_EMAIL=chris@1-group.sg
MASTER_ADMIN_PASSWORD=your-secure-password-here

# JWT secret (random 32+ char string — generate at https://generate-secret.vercel.app/)
JWT_SECRET=your-random-jwt-secret-at-least-32-chars

# ═══════ OPTIONAL ═══════

# Additional admin users (JSON array — generate via Admin Panel → User Management)
# ADMIN_USERS=[{"email":"chef@1-group.sg","name":"Chef Felix","password":"their-password"}]

# Email for password reset (requires Resend account — https://resend.com)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=noreply@1-groupculinary.com

# Base URL (auto-detected in most cases)
# NEXT_PUBLIC_BASE_URL=https://1-groupculinary.com
