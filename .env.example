# 1-CUISINESG Authentication
# Set these in Vercel → Project Settings → Environment Variables

# Master Admin credentials (required)
MASTER_ADMIN_EMAIL=chris@1-group.sg
MASTER_ADMIN_PASSWORD=your-secure-password-here

# JWT secret (required — generate a random string)
JWT_SECRET=your-random-jwt-secret-at-least-32-chars

# Additional admin users (optional — JSON array)
# Generate this via Admin Panel → User Management
# ADMIN_USERS=[{"email":"chef@1-group.sg","name":"Chef Felix","password":"their-password"}]
